{
  "redirects": [
    { "source": "/manual/admin", "destination": "/manual/tecnico/", "permanent": false },
    { "source": "/manual/admin/", "destination": "/manual/tecnico/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/manual/admin/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/manual-admin.pdf",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/manual", "destination": "/manual/index.html" },
    { "source": "/manual/tecnico", "destination": "/manual/tecnico/index.html" }
  ]
}
